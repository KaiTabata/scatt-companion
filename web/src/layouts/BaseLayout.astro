---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SCATT COMPANION',
  description = 'SCATT Expert の補助分析ツール。手のふるえ、呼吸、反動、心拍 / HRV、自然言語フィードバック。',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE = 'https://kaitabata.github.io/scatt-companion';
const ogImage = `${SITE}/og.png`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/img/icon.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}/img/icon.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/img/icon.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="SCATT Companion" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
