---
import Section from './Section.astro';

const modes = [
  {
    name: '伏射 (Prone)',
    target: '50m スポーツライフル',
    focus: 'SCATT 互換 + 反動詳細 + 心拍。',
  },
  {
    name: 'AR (10m エアライフル)',
    target: '立射',
    focus: '撃発時速度・S1・フォロースルーの一貫性。',
  },
  {
    name: 'ホールド練習',
    target: 'ターゲット非依存',
    focus: '銃の静止度だけを見る。重心 R95 と力み中心。',
  },
];
---

<Section id="modes" title="3 つのモード" bg="alt">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-neutral-200 rounded-2xl overflow-hidden">
    {modes.map((m) => (
      <div class="bg-white p-8">
        <p class="text-xs uppercase tracking-widest text-neutral-400 mb-2">{m.target}</p>
        <h3 class="text-xl font-semibold text-neutral-900 mb-3">{m.name}</h3>
        <p class="text-sm text-neutral-500 leading-relaxed">{m.focus}</p>
      </div>
    ))}
  </div>
</Section>
