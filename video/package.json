{
  "name": "scatt-companion-video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "remotion preview src/index.ts",
    "build:pv": "remotion render src/index.ts MarketingPV out/scatt-companion-pv.mp4",
    "build:demo": "remotion render src/index.ts WebsiteDemo out/scatt-companion-demo.mp4",
    "build:cinematic": "remotion render src/index.ts CinematicPV out/scatt-companion-pv-v2.mp4",
    "build:og": "remotion still src/index.ts CinematicPV out/og.png --frame=270 --image-format=png"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "remotion": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
